{
  "compilerOptions": {
    /* ============================
     * Core Options
     * ============================ */
    "target": "ES2022",                    
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",                     // JSX automático (React 17+ / Preact com compatibilidade)
    "moduleResolution": "bundler",         // resolução
    //  de módulos moderna
    "allowJs": true,                        // permite arquivos .js no projeto
    "checkJs": false,                       // mas não faz typecheck de .js
    "resolveJsonModule": true,              // permite importar JSON
    "isolatedModules": true,                // bom para bundlers como RSBuild / Vite
    "esModuleInterop": true,                // melhor compat c/ libs CommonJS
    "skipLibCheck": true,                   // performance (ignora verificação em node_modules)
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },

    /* ============================
     * Strictness
     * ============================ */
    "strict": true,                         // ativa todas as checagens estritas
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* ============================
     * Output
     * ============================ */
    "outDir": "dist",                       // saída do build
    "rootDir": "src",                       // entrada do código fonte

    /* ============================
     * Import Helpers
     * ============================ */
    "importHelpers": true,

    /* ============================
     * Incremental Build
     * ============================ */
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
