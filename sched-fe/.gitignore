# ========================================
# TCS Pace Scheduler - Git Ignore
# ========================================
# This file prevents committing build artifacts, binaries, and temporary files
# Only source code, scripts, and configurations should be versioned

# ========================================
# BUILD OUTPUTS - DO NOT COMMIT
# ========================================
# All compiled binaries and build artifacts are generated by scripts
# and should NEVER be committed to git (use GitHub Releases for distribution)

# Flutter build directory (contains all platform builds)
/build/

# Platform-specific build outputs
/android/app/debug
/android/app/profile
/android/app/release

# Android outputs
build/app/outputs/flutter-apk/*.apk          # APK files (use Firebase Distribution)
build/app/outputs/flutter-apk/*.apk.sha1     # APK checksums
build/app/outputs/bundle/release/*.aab       # Android App Bundles (Google Play)

# Linux outputs
build/linux/x64/release/*.tar.gz             # Compressed archive
build/linux/x64/release/*.AppImage           # Universal Linux executable
build/linux/flatpak/                         # Flatpak build directory
build/linux/squashfs-root/                   # AppImage extracted tool
snap/                                        # Snap package files (keep snapcraft.yaml in git)
!snap/snapcraft.yaml                         # Keep Snap config in git

# Windows outputs
build/windows/x64/runner/Release/*.exe       # Windows executable
build/windows/x64/runner/Release/*.msix      # Microsoft Store package

# macOS/iOS outputs
build/macos/Build/
build/ios/

# Web outputs
build/web/

# ========================================
# DEVELOPMENT TOOLS & CACHES
# ========================================

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# CMake build files
build/.cxx/
.cxx/
*.cmake

# Gradle files
.gradle/
*.hprof

# ========================================
# AI TOOLS & ASSISTANTS
# ========================================
CLAUDE*.md
**/claude-*.log
.aider*
.cursor/

# ========================================
# SECRETS & CERTIFICATES
# ========================================
# Environment variables (API keys, secrets)
.env
.env.local

# Code signing certificates (use secure vault, not git)
tcs_certificate.pfx
*.p12
*.keystore

# Firebase (keep google-services.json for builds, ignore iOS config)
.firebaserc
ios/Runner/GoogleService-Info.plist

# ========================================
# TEMPORARY & BACKUP FILES
# ========================================
*.bak
*.backup
*.tmp
*.pid
*~
