# PRODUCTION ENVIRONMENT
# Database
DATABASE_URL="postgresql://usuario:senha_segura@localhost:5432/tcs_scheduler_prod"

# Server
PORT=7777
NODE_ENV=production

# URLs (IMPORTANTE: Altere para seu domínio)
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://api.seu-dominio.com

# Auth (IMPORTANTE: Gere uma chave segura)
# Use: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_AQUI

# Email Service
RESEND_API_KEY=re_sua_chave_resend

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=seu-project-id-firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSua chave privada aqui (do Firebase Console)\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com

# Security
CORS_ORIGIN=https://seu-dominio.com
MAX_UPLOAD_SIZE=10485760
