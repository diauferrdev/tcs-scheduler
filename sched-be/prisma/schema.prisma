generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum VisitDuration {
  ONE_HOUR
  TWO_HOURS
  THREE_HOURS
  FOUR_HOURS
  FIVE_HOURS
  SIX_HOURS
}

enum EngagementType {
  VISIT
  INNOVATION_EXCHANGE
}

enum VisitType {
  QUICK_TOUR       // DEPRECATED - kept for backwards compatibility, maps to PACE_TOUR
  PACE_TOUR        // 14h-16h (2 hours) - simple visit, no questionnaire
  PACE_EXPERIENCE  // 10h-16h (6 hours) - full day, requires questionnaire
  INNOVATION_EXCHANGE  // 10h-17h (7 hours) - requires questionnaire and alignment call
}

enum BookingStatus {
  PENDING_APPROVAL // DEPRECATED - kept for backwards compatibility, maps to UNDER_REVIEW
  CREATED          // Initial status when booking is submitted
  UNDER_REVIEW     // Manager/Admin is reviewing the booking
  NEED_EDIT        // User must edit information (except date)
  NEED_RESCHEDULE  // User must choose new date
  APPROVED         // Approved and scheduled (time blocked)
  NOT_APPROVED     // Rejected with reason
  CANCELLED        // Manually cancelled
}

enum OrganizationType {
  GOVERNMENTAL_INSTITUTION
  PARTNER
  EXISTING_CUSTOMER
  PROSPECT
  OTHER
}

enum TCSVertical {
  BFSI                  // Banking, Financial Services & Insurance
  RETAIL_CPG            // Retail & Consumer Packaged Goods
  LIFE_SCIENCES_HEALTHCARE  // Life Sciences & Healthcare
  MANUFACTURING
  HI_TECH
  CMT                   // Communications, Media & Technology
  ERU                   // Energy, Resources & Utilities
  TRAVEL_HOSPITALITY    // Travel, Transportation & Hospitality
  PUBLIC_SERVICES
  BUSINESS_SERVICES
}

enum EventType {
  TCS
  PARTNER
}

enum DealStatus {
  SWON
  WON
}

enum TCSSupporter {
  SUPPORTER
  NEUTRAL
  DETRACTOR
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          UserRole  @default(MANAGER)
  isActive      Boolean   @default(true)
  avatarUrl     String?   // Profile picture URL
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  bookingsCreated  Booking[] @relation("CreatedBy")
  bookingsApproved Booking[] @relation("ApprovedBy")
  invitationsCreated Invitation[] @relation("InvitationCreator")
  activityLogs     ActivityLog[]
  pushSubscriptions PushSubscription[]
  bookingParticipations BookingParticipant[]
  notifications    Notification[]
  fcmTokens        FCMToken[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)

  @@index([userId])
}

model Booking {
  id              String         @id @default(cuid())
  date            DateTime       @db.Date
  startTime       String
  duration        VisitDuration

  // New engagement flow
  engagementType  EngagementType @default(VISIT)
  visitType       VisitType      @default(PACE_TOUR)
  status          BookingStatus  @default(CREATED)

  // Base Information (Drawer 2)
  requesterName   String         @default("")  // Name of requester
  employeeId      String         @default("")  // TCS Employee ID
  vertical        TCSVertical    @default(BFSI)  // TCS Vertical
  organizationName String        @default("")  // Organization Name
  organizationType OrganizationType @default(PROSPECT)
  organizationTypeOther String?  // If "OTHER" is selected
  organizationDescription String? @db.Text
  objectiveInterest String?      @db.Text  // Objective / Interest in PacePort
  targetAudience  Json?          // Array of target audience types

  // Questionnaire (for Pace Experience & Innovation Exchange)
  questionnaireAnswers Json?     // Stores 5 questionnaire answers
  requiresAlignmentCall Boolean  @default(false)  // Flag for Pace Experience & Innovation Exchange

  // Legacy Company Info (kept for compatibility)
  accountName     String         @default("")
  companyName     String         @default("")
  companySector   String?
  companyVertical String?
  companySize     String?

  // Contact Info (kept for compatibility)
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  contactPosition String?

  // Visit Details
  venue           String?
  expectedAttendees Int          @default(1)
  overallTheme    String?        // Overall Theme / Focus Area
  lastInnovationDay DateTime?    @db.Date

  // Event Type
  eventType       EventType?
  partnerName     String?

  // Deal Status
  dealStatus      DealStatus?

  // Approvals & Status Management
  attachHeadApproval Boolean    @default(false)
  attachments        Json?      // Array of attachment URLs (up to 6)
  approvedById       String?    // Manager who approved
  approvedBy         User?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt         DateTime?

  // Rejection
  rejectionReason String?       @db.Text  // Reason for Not Approved status
  rejectedById    String?       // Manager who rejected
  rejectedAt      DateTime?

  // Status Change Messages
  editRequestMessage String?    @db.Text  // Message when requesting edit
  rescheduleRequestMessage String? @db.Text  // Message when requesting reschedule

  // Cancellation
  cancellationReason String?    @db.Text  // Reason for cancellation
  cancelledById      String?    // User who cancelled
  cancelledAt        DateTime?  // When was it cancelled

  // Reschedule tracking
  originalBookingId   String?   // If this was rescheduled, reference to original
  rescheduledToId     String?   // If this was rescheduled, reference to new booking

  // Legacy fields (kept for compatibility)
  interestArea    String?
  businessGoal    String?
  additionalNotes String?        @db.Text

  invitationId    String?        @unique
  invitation      Invitation?    @relation(fields: [invitationId], references: [id])
  createdById     String?
  createdBy       User?          @relation("CreatedBy", fields: [createdById], references: [id])

  attendees       Attendee[]
  participants    BookingParticipant[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([date])
  @@index([status])
  @@index([createdById])
  @@index([engagementType])
  @@index([visitType])
  @@index([vertical])
}

model Attendee {
  id        String   @id @default(cuid())

  // Basic Info
  name      String
  email     String
  role      String?

  // TCS Relationship
  tcsSupporter         TCSSupporter?
  understandingOfTCS   String?        @db.Text
  focusAreas           String?        @db.Text
  yearsWorkingWithTCS  Int?

  // Professional Info
  position             String?
  educationalQualification String?    @db.Text
  careerBackground     String?        @db.Text
  linkedinProfile      String?

  // Optional
  photoUrl             String?

  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

model Invitation {
  id              String    @id @default(cuid())
  token           String    @unique
  email           String?
  expiresAt       DateTime
  usedAt          DateTime?
  isActive        Boolean   @default(true)

  createdById     String
  createdBy       User      @relation("InvitationCreator", fields: [createdById], references: [id])

  booking         Booking?

  createdAt       DateTime  @default(now())

  @@index([token])
  @@index([createdById])
  @@index([expiresAt])
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  VIEW
}

enum ActivityResource {
  BOOKING
  INVITATION
  USER
  SESSION
}

model ActivityLog {
  id          String            @id @default(cuid())
  action      ActivityAction
  resource    ActivityResource
  resourceId  String?
  description String
  metadata    Json?

  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      Json
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([endpoint])
}

enum ParticipantStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model BookingParticipant {
  id          String             @id @default(cuid())
  userId      String
  bookingId   String
  status      ParticipantStatus  @default(PENDING)
  invitedById String?
  invitedAt   DateTime           @default(now())
  respondedAt DateTime?

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking     Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([userId, bookingId])
  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

enum NotificationType {
  BOOKING_INVITATION
  BOOKING_PENDING_APPROVAL     // DEPRECATED - kept for backwards compatibility
  BOOKING_CONFIRMED            // DEPRECATED - kept for backwards compatibility
  BOOKING_CREATED              // New booking submitted (CREATED status)
  BOOKING_UNDER_REVIEW         // Booking moved to under review
  BOOKING_NEED_EDIT            // User must edit information
  BOOKING_NEED_RESCHEDULE      // User must reschedule
  BOOKING_APPROVED             // Manager approved the booking
  BOOKING_NOT_APPROVED         // Manager rejected the booking
  BOOKING_UPDATED
  BOOKING_IMPORTANT_CHANGE     // Important data changed
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  PARTICIPANT_CONFIRMED
  PARTICIPANT_REJECTED
}

model Notification {
  id        String            @id @default(cuid())
  type      NotificationType
  title     String
  message   String            @db.Text
  userId    String
  bookingId String?
  isRead    Boolean           @default(false)
  readAt    DateTime?
  actionUrl String?
  metadata  Json?

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now())

  @@index([userId])
  @@index([bookingId])
  @@index([isRead])
  @@index([createdAt])
}

// Firebase Cloud Messaging Tokens (for mobile push notifications)
model FCMToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo String?  @db.Text // Device model, OS version, etc
  lastUsedAt DateTime @default(now())
  isValid    Boolean  @default(true) // Marked false if FCM returns UNREGISTERED/INVALID

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([isValid])
}

// FCM Push Notification Analytics
model FCMAnalytics {
  id              String   @id @default(cuid())
  userId          String   // Who received the notification
  notificationId  String?  // Reference to Notification if applicable
  fcmTokenId      String?  // Which token was used

  title           String
  message         String   @db.Text

  sentAt          DateTime @default(now())
  delivered       Boolean  @default(false)
  deliveredAt     DateTime?

  failed          Boolean  @default(false)
  failureReason   String?  @db.Text

  clicked         Boolean  @default(false)
  clickedAt       DateTime?

  metadata        Json?

  @@index([userId])
  @@index([notificationId])
  @@index([sentAt])
  @@index([delivered])
  @@index([clicked])
}
